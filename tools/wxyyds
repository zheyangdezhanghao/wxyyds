def repo_root() -> Path:
    env = os.environ.get("WXYYDS_HOME")
    if env:
        return Path(env)
    return Path(__file__).resolve().parent.parent


def detect_arch() -> str:
    import platform

    m = platform.machine().lower()
    if m in ("arm64", "aarch64"):
        return "arm64"
    return "x86_64"


def read_build(app: Path) -> str | None:
    plist_path = app / "Contents/Info.plist"
    if not plist_path.exists():
        return None
    with plist_path.open("rb") as f:
        plist = plistlib.load(f)
    return str(plist.get("CFBundleVersion", ""))


def read_short_version(app: Path) -> str | None:
    plist_path = app / "Contents/Info.plist"
    if not plist_path.exists():
        return None
    with plist_path.open("rb") as f:
        plist = plistlib.load(f)
    return str(plist.get("CFBundleShortVersionString", ""))


def load_manifest(root: Path) -> dict:
    path = root / "offsets/manifest.json"
    with path.open() as f:
        return json.load(f)


def load_configs(root: Path) -> list[dict]:
    path = root / "offsets/config.json"
    with path.open() as f:
        return json.load(f)


def supported_builds(root: Path, arch: str) -> list[str]:
    builds = []
    for cfg in load_configs(root):
        for target in cfg.get("targets", []):
            for entry in target.get("entries", []):
                if entry.get("arch") == arch:
                    builds.append(cfg["version"])
                    break
    return sorted(set(builds), key=int)


def is_supported(root: Path, build: str, arch: str) -> bool:
    return build in supported_builds(root, arch)


def build_info(root: Path) -> dict[str, dict]:
    """build -> {archs, short from manifest if any}"""
    info: dict[str, dict] = {}
    for cfg in load_configs(root):
        b = cfg["version"]
        if b not in info:
            info[b] = {"archs": set(), "targets": set()}
        for target in cfg.get("targets", []):
            info[b]["targets"].add(target.get("identifier", "?"))
            for entry in target.get("entries", []):
                a = entry.get("arch")
                if a:
                    info[b]["archs"].add(a)
    return info


def manifest_fallback(root: Path) -> dict[str, dict]:
    m = load_manifest(root)
    return m.get("fallback", {})


def cmd_versions(args: argparse.Namespace) -> int:
    root = repo_root()
    host_arch = detect_arch()
    app = Path(args.app)
    build = read_build(app) if app.exists() else None
    short = read_short_version(app) if app.exists() else None
    all_info = build_info(root)
    fb = manifest_fallback(root)

    print("------ wxyyds 版本支持 ------")
    print(f"本机架构:   {host_arch}")
    print(f"CLI:        {VERSION}")
    if build:
        supported = is_supported(root, build, host_arch)
        print(f"当前微信:   {short or '?'} (build {build})")
        print(f"本机可用:   {'✅ 是' if supported else '❌ 否'}")
    else:
        print("当前微信:   未找到或无法读取")

    print("")
    print("------ 推荐版本 (fallback) ------")
    for arch in ("x86_64", "arm64"):
        f = fb.get(arch, {})
        label = "Intel" if arch == "x86_64" else "Apple Silicon"
        if f:
            print(
                f"  {label:16s} build {f.get('build', '?')} "
                f"({f.get('note', f.get('canc3s_tag', ''))})"
            )
        else:
            print(f"  {label:16s} (未配置)")

    print("")
    print("------ Intel (x86_64) ------")
    x64 = [b for b, i in all_info.items() if "x86_64" in i["archs"]]
    for b in sorted(x64, key=int, reverse=True)[:8]:
        mark = " ← 当前" if b == build and host_arch == "x86_64" else ""
        latest = " [最新]" if fb.get("x86_64", {}).get("build") == b else ""
        print(f"  ✅ build {b}{latest}{mark}")
    if len(x64) > 8:
        print(f"  ... 共 {len(x64)} 个 build")

    print("")
    print("------ Apple Silicon (arm64) ------")
    arm = [b for b, i in all_info.items() if "arm64" in i["archs"]]
    for b in sorted(arm, key=int, reverse=True):
        mark = " ← 当前" if b == build and host_arch == "arm64" else ""
        latest = " [推荐]" if fb.get("arm64", {}).get("build") == b else ""
        print(f"  ✅ build {b}{latest}{mark}")

    print("")
    print("------ 本机不可用但常见的 build ------")
    if host_arch == "arm64":
        if "269077" not in arm:
            cur = " ← 你当前的版本" if build == "269077" else ""
            print(f"  ❌ build 269077 (4.1.11) — 无 arm64 offsets{cur}")
            print("     M 系列请降级到 build 32288 (4.1.5.28)，聊天记录保留")
    elif host_arch == "x86_64" and build and build not in x64:
        print(f"  ❌ build {build} — 无 x86_64 offsets")

    print("")
    print("详细说明: docs/GUIDE.md")
    return 0


def cmd_patch(args: argparse.Namespace) -> int:
    root = repo_root()
    arch = detect_arch()
    app = Path(args.app)
    build = read_build(app)
    if not build:
        print("ERROR: Cannot read WeChat CFBundleVersion", file=sys.stderr)
        return 1

    if not is_supported(root, build, arch):
        print(f"ERROR: Build {build} not supported on {arch}", file=sys.stderr)
        print("Run: wxyyds install  (auto downgrade to supported version)", file=sys.stderr)
        return 1

    patcher = root / "tools/patcher.py"
    config = root / "offsets/config.json"
    rc = subprocess.call(
        [sys.executable, str(patcher), str(app), str(config), build, arch]
    )
    if rc != 0:
        return rc

    print("------ Resign ------")
    for cmd in [
        ["codesign", "--remove-sign", str(app)],
        ["codesign", "--force", "--deep", "--sign", "-", str(app)],
        ["xattr", "-cr", str(app)],
    ]:
        subprocess.run(cmd, check=False)
    print("Done!")
    return 0


def cmd_update(args: argparse.Namespace) -> int:
    root = repo_root()
    print(BANNER)
    print("Checking for wxyyds updates...")

    remote_manifest_url = os.environ.get(
        "WXYYDS_MANIFEST_URL",
        "https://raw.githubusercontent.com/wxyyds/wxyyds/main/offsets/manifest.json",
    )
    try:
        with urllib.request.urlopen(remote_manifest_url, timeout=10) as resp:
            remote = json.loads(resp.read().decode())
        print(f"Remote manifest updated: {remote.get('updated', 'unknown')}")
    except Exception as e:
        print(f"WARN: Cannot fetch remote manifest: {e}")
        print("Using local offsets only.")

    config_url = os.environ.get(
        "WXYYDS_CONFIG_URL",
        "https://raw.githubusercontent.com/wxyyds/wxyyds/main/offsets/config.json",
    )
    try:
        with urllib.request.urlopen(config_url, timeout=15) as resp:
            remote_cfg = json.loads(resp.read().decode())
        local_cfg_path = root / "offsets/config.json"
        local_cfg_path.write_text(json.dumps(remote_cfg, indent=2) + "\n")
        print(f"Updated offsets/config.json ({len(remote_cfg)} versions)")
    except Exception as e:
        print(f"WARN: Cannot update config.json: {e}")

    fw_path = root / "Rely/Plugin/WXYyds.framework"
    if fw_path.exists():
        print("Framework present locally. Re-run install to re-inject.")
    else:
        print("Framework not bundled. Binary patch mode only.")

    print("\n🔄 wxyyds offsets updated. Run install.sh to re-apply patches.")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="wxyyds",
        description="wxyyds — 一个极客的理想之地",
    )
    parser.add_argument("--app", default=str(DEFAULT_APP), help="WeChat.app path")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("versions", help="List supported versions").set_defaults(
        func=cmd_versions
    )
    sub.add_parser("patch", help="Patch WeChat.app").set_defaults(func=cmd_patch)
    sub.add_parser("update", help="Update offsets from remote").set_defaults(
        func=cmd_update
    )

    args = parser.parse_args()
    if not args.command:
        print(BANNER)
        parser.print_help()
        return 0
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
